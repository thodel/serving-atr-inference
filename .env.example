# Copy to .env on each VM and set the shared key.
# The gateway and the client (agentic_historian) use the SAME value.
ATR_API_KEY=replace-with-a-long-random-shared-secret

# Optional overrides (defaults shown — tuned for asterAIx, see docs/asteraix-environment.md)
# ATR_HOST=0.0.0.0
# ATR_PORT=8200
# ATR_REQUIRE_AUTH=true
# ATR_KRAKEN_URL=http://127.0.0.1:8201
# ATR_TROCR_URL=http://127.0.0.1:8202
# ATR_PARTY_URL=http://127.0.0.1:8203

# Keep model downloads off the (80%-full) shared root partition default location
# and in one managed dir we can monitor.
HF_HOME=/home/tobias/atr-cache/hf
